{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/scripts/*": ["./scripts/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/prisma/client/*": ["./src/prisma/client/*"]
    },
    "noImplicitAny": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "moduleDetection": "force",
    "module": "Preserve",
    "allowJs": true
  },
  "include": ["scripts/**/*.ts", "src/lib/prisma/**/*.ts", "src/lib/auction/**/*.ts", "src/lib/actions/**/*.ts", "src/prisma/client/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts", "src/app", "src/components", "src/hooks"]
}
