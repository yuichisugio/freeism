# DATABASE の設定
DATABASE_URL=
DIRECT_URL=

# Supabase の設定
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auht.jsの設定
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Node Environment
NODE_ENV=

# Cloudflare R2の設定
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_PUBLIC_URL=
ENABLE_IMAGE_UPLOAD=
NEXT_PUBLIC_ENABLE_IMAGE_UPLOAD=
# ↑は、画像アップロードの設定。trueにすることで、画像を添付できるようになる

# Resendの設定
RESEND_API_KEY=

# VAPIDの設定
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
