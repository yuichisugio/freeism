// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  plugin   = "@prisma/nextjs-monorepo-workaround-plugin"
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String            @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  isAppOwner    Boolean           @default(false) @map("is_app_owner")
  accounts      Account[]
  sessions      Session[]
  settings      UserSettings?
  groups        Group[]
  memberships   GroupMembership[]
  taskCreator   Task[]            @relation("TaskCreator")
  userFixedSubmitter Task[]            @relation("UserFixedSubmitter")
  notifications Notification[]
  analytics     Analytics[]
  taskReporter  TaskReporter[]
  taskExecutor  TaskExecutor[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text @map("refresh_token")
  access_token      String? @db.Text @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @db.Text @map("id_token")
  session_state     String? @map("session_state")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  username  String
  lifeGoal  String   @db.Text @map("life_goal")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id               String            @id @default(cuid())
  name             String            @unique
  goal             String
  evaluationMethod String            @map("evaluation_method")
  depositPeriod    Int               @default(30) @map("deposit_period") // ポイント預け入れ期間
  maxParticipants  Int               @default(100) @map("max_participants") // 最大参加者数
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  createdBy        String            @map("created_by")
  isBlackList      Json?             @db.JsonB @map("is_black_list") // 除名されたユーザーのリスト（userIdをキーとして値にtrueを格納）
  user             User              @relation(fields: [createdBy], references: [id])
  members          GroupMembership[]
  tasks            Task[]
  analytics        Analytics[]
  notifications    Notification[]

  @@index([createdBy])
}

model GroupMembership {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  groupId      String   @map("group_id")
  joinedAt     DateTime @default(now()) @map("joined_at")
  isGroupOwner Boolean  @default(false) @map("is_group_owner")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model Task {
  id                     String         @id @default(cuid())
  task                   String // タスクのタイトル
  detail                 String? // タスクの詳細
  reference              String? // 参考にした内容
  status                 TaskStatus     @default(PENDING)
  fixedContributionPoint Int?           @map("fixed_contribution_point")
  fixedEvaluator         String?        @map("fixed_evaluator")
  fixedEvaluationLogic   String?        @map("fixed_evaluation_logic")
  fixedEvaluationDate    DateTime?      @map("fixed_evaluation_date")
  userFixedSubmitter     User?          @relation("UserFixedSubmitter", fields: [userFixedSubmitterId], references: [id], onDelete: Cascade) // 固定評価者
  userFixedSubmitterId   String?        @map("user_fixed_submitter_id")
  info                   String?       // 証拠・結果・補足情報
  imageUrl               String?        @map("image_url") // 報酬画像のURL
  contributionType       contributionType @default(NON_REWARD) @map("contribution_type") // "REWARD" or "NON_REWARD"
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  creator                User           @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId              String         @map("creator_id")
  reporters              TaskReporter[]
  executors              TaskExecutor[]
  group                  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId                String
  analytics              Analytics[]
  notifications          Notification[]

  @@index([creatorId])
  @@index([groupId])
}

enum contributionType {
  REWARD // 報酬タスク
  NON_REWARD // 報酬なしタスク
}

model Analytics {
  id                String   @id @default(cuid())
  contributionPoint Int      @map("contribution_point")
  evaluationLogic   String   @map("evaluation_logic")
  evaluator         String
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  taskId            String   @map("task_id")
  task              Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  groupId           String   @map("group_id")
  group             Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [evaluator], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([groupId])
}

enum TaskStatus {
  PENDING // タスク実施予定
  BIDDED // 落札済み。報酬あり専用
  POINTS_DEPOSITED // ポイント預け済み。報酬あり専用
  TASK_COMPLETED // タスク完了。報酬の有無関係なしで、タスクが完了した場合に使用
  FIXED_EVALUATED // ポイント額がFIXED_CONTRIBUTION_POINTによって評価されたときに使用
  POINTS_AWARDED // ポイントの付与が完了したときに使用
  ARCHIVED // タスクをアーカイブしたときに使用
}

// 通知タイプの列挙型
enum NotificationType {
  INFO
  SUCCESS
  WARNING
}

// 通知対象の種類を定義
enum NotificationTargetType {
  SYSTEM // システム全体の通知
  USER // 特定ユーザーへの通知
  GROUP // 特定グループへの通知
  TASK // 特定タスクに関する通知
}

// 通知テーブル
model Notification {
  id         String                 @id @default(cuid())
  title      String // 通知タイトル
  message    String                 @db.Text // 通知メッセージ内容
  type       NotificationType       @map("type") // 通知の重要度/種類
  targetType NotificationTargetType @map("target_type") // 通知対象の種類
  sentAt     DateTime               @default(now()) @map("sent_at") // 送付時間
  expiresAt  DateTime?              @map("expires_at") // 通知の有効期限（オプション）
  actionUrl  String?                @map("action_url") // クリック時の遷移先URL（オプション）
  priority   Float                  @default(1.0) // 通知の優先度 (1-5, 5が最高)
  isRead     Json                   @default("{}") @db.JsonB // ユーザーごとの既読状態 { userId: { isRead: boolean, readAt: timestamp } }

  // user宛の場合は、userIdを入れる。
  userId String? @map("user_id") // 通知の送信者/作成者
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // グループ関連（オプション）
  groupId String? @map("group_id")
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // タスク関連（オプション）
  taskId String? @map("task_id")
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupId])
  @@index([taskId])
}

// 新しく追加: タスク報告者モデル
model TaskReporter {
  id        String    @id @default(cuid())
  name      String?   // 未登録ユーザーの場合は名前のみ
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?   @map("user_id") // 登録ユーザーの場合はID紐づけ (オプショナル)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String    @map("task_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([taskId])
}

// 新しく追加: タスク実行者モデル
model TaskExecutor {
  id        String    @id @default(cuid())
  name      String?   // 未登録ユーザーの場合は名前のみ
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?   @map("user_id") // 登録ユーザーの場合はID紐づけ (オプショナル)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String    @map("task_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([taskId])
}
