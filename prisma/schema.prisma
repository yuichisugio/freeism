// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  plugin   = "@prisma/nextjs-monorepo-workaround-plugin"
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String            @unique
  emailVerified DateTime?
  image         String?
  isAppOwner    Boolean           @default(false)
  accounts      Account[]
  sessions      Session[]
  settings      UserSettings?
  groups        Group[]
  memberships   GroupMembership[]
  tasks         Task[]
  notifications Notification[]
  analytics     Analytics[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  username  String
  lifeGoal  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id               String            @id @default(cuid())
  name             String            @unique
  goal             String
  evaluationMethod String
  maxParticipants  Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        String
  isBlackList      Json?             @db.JsonB // 除名されたユーザーのリスト（userIdをキーとして値にtrueを格納）
  user             User              @relation(fields: [createdBy], references: [id])
  members          GroupMembership[]
  tasks            Task[]
  analytics        Analytics[]
  notifications    Notification[]

  @@index([createdBy])
}

model GroupMembership {
  id           String   @id @default(cuid())
  userId       String
  groupId      String
  joinedAt     DateTime @default(now())
  isGroupOwner Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model Task {
  id                     String         @id @default(cuid())
  task                   String
  reference              String?
  status                 TaskStatus     @default(PENDING)
  fixedContributionPoint Int?
  fixedEvaluator         String?
  fixedEvaluationLogic   String?
  info                   String?
  contributionType       String         @default("NON_REWARD") // "REWARD" or "NON_REWARD"
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String
  group                  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId                String
  analytics              Analytics[]
  notifications          Notification[]

  @@index([userId])
  @@index([groupId])
}

model Analytics {
  id                String   @id @default(cuid())
  contributionPoint Int
  evaluationLogic   String
  evaluator         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  taskId            String
  task              Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  groupId           String
  group             Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [evaluator], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([groupId])
}

enum TaskStatus {
  PENDING // タスク実施予定
  BIDDED // 落札済み。報酬あり専用
  POINTS_DEPOSITED // ポイント預け済み。報酬あり専用
  TASK_COMPLETED // タスク完了。報酬の有無関係なしで、タスクが完了した場合に使用
  FIXED_EVALUATED // ポイント額がFIXED_CONTRIBUTION_POINTによって評価されたときに使用
  POINTS_AWARDED // ポイントの付与が完了したときに使用
  ARCHIVED // タスクをアーカイブしたときに使用
}

// 通知タイプの列挙型
enum NotificationType {
  INFO
  SUCCESS
  WARNING
}

// 通知対象の種類を定義
enum NotificationTargetType {
  SYSTEM // システム全体の通知
  USER // 特定ユーザーへの通知
  GROUP // 特定グループへの通知
  TASK // 特定タスクに関する通知
}

// 通知テーブル
model Notification {
  id         String                 @id @default(cuid())
  title      String // 通知タイトル
  message    String                 @db.Text // 通知メッセージ内容
  type       NotificationType // 通知の重要度/種類
  targetType NotificationTargetType // 通知対象の種類
  sentAt     DateTime               @default(now()) // 送付時間
  expiresAt  DateTime? // 通知の有効期限（オプション）
  actionUrl  String? // クリック時の遷移先URL（オプション）
  priority   Float                  @default(1.0) // 通知の優先度 (1-5, 5が最高)
  isRead     Json                   @default("{}") @db.JsonB // ユーザーごとの既読状態 { userId: { isRead: boolean, readAt: timestamp } }

  // user宛の場合は、userIdを入れる。
  userId String? // 通知の送信者/作成者
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // グループ関連（オプション）
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // タスク関連（オプション）
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupId])
  @@index([taskId])
}
