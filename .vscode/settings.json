{
	// ファイルネスティングを有効化
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,

	// このリポジトリ専用のファイルネスティングパターン
	"explorer.fileNesting.patterns": {
		// package.json関連のファイルをネスト
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, .textlintrc, .markdownlint.json,.gitignore,LICENSE.md",
	}
}
