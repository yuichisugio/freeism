{
  "name": "freeism-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "email:dev": "email dev -d ./src/emails -p 3001",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf node_modules dist",
    "lint": "next lint && prisma validate",
    "lint:fix": "next lint --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,cjs,mjs,md,json,lintstagedrc,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,md,json,lintstagedrc,yml,yaml}\" && prisma format",
    "prepare": "husky",
    "commit": "git-cz",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "db:seed": "prisma db seed",
    "actions:update-auction-status-to-active": "tsx scripts/update-auction-status-to-active.ts",
    "actions:update-auction-status-to-completed": "tsx scripts/update-auction-status-to-completed.ts",
    "actions:return-auction-deposit-points": "tsx scripts/return-auction-deposit-points.ts",
    "actions:send-scheduled-notifications": "tsx scripts/send-scheduled-notifications.ts",
    "prisma:dev:migrate": "pnpm dotenv -e .env -- pnpm prisma migrate dev",
    "prisma:prod:deploy": "pnpm dotenv -e .env.production -- pnpm prisma migrate deploy"
  },
  "prisma": {
    "seed": "pnpm vite-node prisma/seed.ts"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,md,json,lintstagedrc,yml,yaml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,lintstagedrc,yml,yaml}": [
      "prettier --write"
    ],
    "**/*.prisma": [
      "prisma format"
    ]
  },
  "dependencies": {
    "@apollo/client": "^3.12.11",
    "@apollo/server": "^4.11.3",
    "@as-integrations/next": "^3.2.0",
    "@auth/nextjs": "0.0.0-380f8d56",
    "@auth/prisma-adapter": "^2.8.0",
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@hookform/resolvers": "^4.0.0",
    "@prisma/nextjs-monorepo-workaround-plugin": "^6.4.1",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-email/components": "0.0.36",
    "@reduxjs/toolkit": "^2.5.1",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@vercel/analytics": "^1.5.0",
    "argon2": "^0.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "date-fns": "^3.6.0",
    "fflate": "^0.8.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.4.10",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "lucide-react": "^0.471.2",
    "next": "15.1.4",
    "next-auth": "5.0.0-beta.25",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.4",
    "papaparse": "^5.5.2",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.5.2",
    "react-redux": "^9.2.0",
    "resend": "^4.2.0",
    "sharp": "^0.33.5",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.20.0",
    "@faker-js/faker": "^9.5.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@prisma/client": "^6.6.0",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/eslint": "^9.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "autoprefixer": "^10.4.20",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "esm": "^3.2.25",
    "glob": "10.3.10",
    "husky": "^9.1.7",
    "inflight": "1.0.6",
    "lint-staged": "^15.3.0",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.6.0",
    "react-email": "4.0.4",
    "tailwind-scrollbar-hide": "^2.0.0",
    "tailwindcss": "^4.0.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.15",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite-node": "^3.0.7",
    "vitest": "^3.0.7"
  }
}
