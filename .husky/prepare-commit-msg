#!/usr/bin/env sh

# Commitizenでコミットメッセージを作成し、エディタが開かないようにする
if [ "${COMMITIZEN_HOOK_SKIP}" = "1" ]; then
  # すでに Commitizen が実行済みの場合はスキップし、環境変数をリセット
  unset COMMITIZEN_HOOK_SKIP
  exit 0
fi

if [ -z "$2" ] || [ "$2" = "message" ]; then
  # 標準入力をターミナルに接続してCommitizenを実行
  exec < /dev/tty
  # 二重実行を防ぐためのフラグを設定
  export COMMITIZEN_HOOK_SKIP=1
  npx cz --hook || exit 1
fi
