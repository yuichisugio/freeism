#!/usr/bin/env sh

# ===== 0) Rosetta で走っている macOS Intel だけ arm64 で再実行 =====
if [ "$(uname -s)" = "Darwin" ] && [ "$(uname -m)" != "arm64" ]; then
  if /usr/bin/arch -arm64 true 2>/dev/null ; then       # Intel Mac では false を返す
    echo "🔄  Re-launching hook under arm64..."
    exec /usr/bin/arch -arm64 /bin/sh "$0" "$@"
  fi
fi
# ここに来る時点で
#   • Apple Silicon → すでに arm64
#   • Intel Mac     → arch -arm64 が無いので再実行せずそのまま
#   • Linux/Windows CI → uname -s が Darwin ではないので分岐をスキップ

# ===== 1) 通常のgit commit時のlint処理 =====
# COMMITIZEN_HOOK_SKIPが設定されていない場合（通常のgit commit）はここでlint実行
if [ "$COMMITIZEN_HOOK_SKIP" != "1" ]; then
  echo "🔍 Running lint-staged..."
  npx lint-staged --concurrent false
fi
